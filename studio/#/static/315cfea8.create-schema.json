[
  {
    "options": {
      "collapsible": true,
      "collapsed": true
    },
    "fields": [
      {
        "description": "Overrides the browser tab / search title. ~50–60 characters.",
        "name": "metaTitle",
        "type": "string",
        "title": "Meta title"
      },
      {
        "rows": 2,
        "validation": [
          {
            "rules": [
              {
                "flag": "max",
                "constraint": 160
              }
            ],
            "level": "warning",
            "message": "Keep under ~160 characters."
          }
        ],
        "name": "metaDescription",
        "type": "text",
        "title": "Meta description"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Used when the page is shared (Open Graph / Twitter).",
        "name": "ogImage",
        "type": "image",
        "title": "Social share image"
      }
    ],
    "name": "seo",
    "type": "object",
    "title": "SEO"
  },
  {
    "fields": [
      {
        "options": {
          "list": [
            {
              "title": "LinkedIn",
              "value": "linkedin"
            },
            {
              "title": "Instagram",
              "value": "instagram"
            },
            {
              "title": "X / Twitter",
              "value": "twitter"
            },
            {
              "title": "Behance",
              "value": "behance"
            },
            {
              "title": "Dribbble",
              "value": "dribbble"
            },
            {
              "title": "Other",
              "value": "other"
            }
          ]
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "linkedin",
                  "instagram",
                  "twitter",
                  "behance",
                  "dribbble",
                  "other"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "platform",
        "type": "string"
      },
      {
        "description": "Shown text, e.g. \"LinkedIn\".",
        "name": "label",
        "type": "string"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ],
            "level": "error"
          }
        ],
        "name": "url",
        "type": "url",
        "title": "URL"
      }
    ],
    "name": "socialLink",
    "type": "object",
    "title": "Social link"
  },
