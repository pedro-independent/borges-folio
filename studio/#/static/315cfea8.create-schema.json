  {
    "fields": [
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "title",
        "type": "string"
      },
      {
        "options": {
          "source": "title",
          "maxLength": 96
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "slug",
        "type": "slug"
      },
      {
        "description": "e.g. \"Cyber Security · SaaS\".",
        "name": "category",
        "type": "string"
      },
      {
        "description": "Short line shown on cards (Work grid / home), e.g. \"B2B SaaS conversion-focused website\".",
        "name": "subtitle",
        "type": "string"
      },
      {
        "rows": 3,
        "description": "Longer summary used on the project detail page.",
        "name": "description",
        "type": "text"
      },
      {
        "options": {
          "hotspot": true
        },
        "name": "cover",
        "type": "image",
        "title": "Cover image"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "regex",
                "constraint": {
                  "pattern": "/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/",
                  "name": "hex colour",
                  "invert": false
                }
              }
            ],
            "level": "warning",
            "message": "Use a hex colour like #cdb8f2."
          }
        ],
        "description": "Hex colour used as the card / placeholder background, e.g. \"#cdb8f2\".",
        "name": "tint",
        "type": "string",
        "title": "Placeholder tint"
      },
      {
        "options": {
          "layout": "tags"
        },
        "of": [
          {
            "type": "string"
          }
        ],
        "name": "services",
        "type": "array"
      },
      {
        "description": "Manual sort position (ascending). Drives the Archive order.",
        "name": "sortOrder",
        "type": "number",
        "title": "Order"
      },
      {
        "initialValue": false,
        "description": "Show in the Work page \"Featured\" section.",
        "name": "featured",
        "type": "boolean"
      },
      {
        "initialValue": false,
        "description": "Mark as not-yet-published in the grid.",
        "name": "comingSoon",
        "type": "boolean",
        "title": "Coming soon"
      },
      {
        "description": "Used to group the Work \"Archive\".",
        "name": "year",
        "type": "number"
      },
      {
        "description": "Number of awards (shown as a badge).",
        "name": "awards",
        "type": "number"
      },
      {
        "rows": 3,
        "name": "problem",
        "type": "text"
      },
      {
        "of": [
          {
            "fields": [
              {
                "name": "label",
                "type": "string"
              },
              {
                "name": "value",
                "type": "string"
              }
            ],
            "type": "object"
          }
        ],
        "name": "outcomes",
        "type": "array"
      },
      {
        "options": {
          "collapsible": true
        },
        "fields": [
          {
            "rows": 3,
            "name": "statement",
            "type": "text"
          },
          {
            "name": "scope",
            "type": "string"
          },
          {
            "name": "methods",
            "type": "string"
          },
          {
            "of": [
              {
                "options": {
                  "hotspot": true
                },
                "type": "image"
              }
            ],
            "name": "media",
            "type": "array"
          }
        ],
        "name": "role",
        "type": "object"
      },
      {
        "of": [
          {
            "fields": [
              {
                "name": "heading",
                "type": "string"
              },
              {
                "rows": 4,
                "name": "body",
                "type": "text"
              },
              {
                "options": {
                  "hotspot": true
                },
                "name": "image",
                "type": "image"
              }
            ],
            "type": "object"
          }
        ],
        "name": "decisions",
        "type": "array",
        "title": "Key decisions"
      },
      {
        "options": {
          "collapsible": true,
          "collapsed": true
        },
        "name": "seo",
        "type": "seo",
        "title": "SEO"
