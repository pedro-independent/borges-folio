SANITY_PROJECT_ID=xxxxxxxx
SANITY_DATASET=production

# Feedback tool (/feedback layer)
# Sanity token with write access — REQUIRED in production/preview (read-only FS).
# In local dev it's optional: comments fall back to .data/feedback.json.
SANITY_API_WRITE_TOKEN=
# Force-enable the tool in a production build (e.g. the client-review preview).
# Leave unset/false for the real launch. Always on in `nuxt dev`.
FEEDBACK_ENABLED=
